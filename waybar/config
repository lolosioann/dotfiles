{
  "layer": "top",
  "position": "top",
  "reload_style_on_change": true, 

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "bluetooth", "cpu", "memory", "temperature", "wireplumber", "hyprland/language", "battery"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "hyprctl dispatch workspace {id}",
    "format-icons": {
      "default": "έΩΜ",
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
    },
    "sort-by-number": true,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    }
  },

  "clock": {
    "interval": 60,
    "format": "{:%a %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "on-scroll": 1,
      "format": {
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
  },


  "hyprland/language": {
    "format-en": "en",
    "format-gr": "gr",
  },

  "network": {
    "interval": 5, 
    "format-wifi": "ΎΘτ {essid}",
    "format-ethernet": "έυΘ {bandwidthDownBytes} έυΗ {bandwidthUpBytes}",
    "format": "ΎΑΤ",
    "format-disabled": "",
    "format-disconnected": "ΎγΦ",
    "on-click": "kitty",
    "tooltip-format": "ΎΓΥ  {bandwidthUpBits}  ΎΑβ  {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
    "tooltip-format-wifi": "ΎΘτ   {essid} @{frequency}MHz\nStrength:  {signaldBm} dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nΎΓΥ  {bandwidthUpBits} ΎΑβ {bandwidthDownBits}",
    },

  "wireplumber": {
    "max-volume": 100,
    "states": {
      "high": 100,
      "mid": 70,
      "low": 35
    },
    "format": "{icon} {volume}%",
    "format-muted": "Ό╗ρ  {volume}%",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
  },

  "battery": {
    "states": {
      "warning": 30
    },
    "format": "{icon} {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-warning": "≤░ΓΔ {capacity}%",
    "tooltip-format": "{capacity}%",
    "on-click": "exec killall -SIGUSR2 waybar && waybar",
  },

  "bluetooth": {
    "format": "ΎΛΦ {status}",
    "format-on": "ΎΛΦ On",
    "format-off": "ΎΛΦ Off",
    "format-disabled": "ΎΛΦ Dis",
    "format-connected": "ΎΛΦ {num_connections}"
  },

  "cpu": {
    "format": "ΎΜδ {usage}%",
  }, 

  "memory": {
    "format": "ΌΚο {used:0.1f}G",
    "tooltip": false
  },

  "temperature": {
    "critical-threshold": 70,
    "format": "ΎΜΚ {temperatureC}┬░C"
}
}
