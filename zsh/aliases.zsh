alias gz='QT_QPA_PLATFORM=xcb gazebo.gz'
alias dockup='docker compose -f ~/Devel/vroomitor/docker-compose.yml up -d --build'
alias dockdown='docker compose -f ~/Devel/vroomitor/docker-compose.yml down'
