alias ls='eza --icons --group-directories-first'
alias open='xdg-open'
alias find='fd'
alias grep='/usr/bin/grep'
# alias grep='rg'
alias gdiff='git difftool --no-symlinks --dir-diff'
alias pbcopy='xclip -selection clipboard'
alias pbpaste='xclip -selection clipboard -o'
